# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# --- Postgres ---
DATABASE_URL=postgres://scheduler:scheduler_dev_pw@localhost:5432/job_scheduler
DB_POOL_MAX=20

# --- Redis (rate limiting, distributed lock, pub/sub for WS fan-out) ---
REDIS_URL=redis://localhost:6379

# --- Worker process ---
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=750
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_LEASE_MS=30000
WORKER_SHUTDOWN_GRACE_MS=15000

# --- Scheduler process ---
SCHEDULER_TICK_MS=2000
SCHEDULER_LOCK_TTL_MS=10000
